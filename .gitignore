# Go build artifacts
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Binaries accidentally built inside example subdirs — extensionless
# Go binaries that `go build` produces if you omit -o.
/example/*/*
!/example/*/*.go
!/example/*/README.md

# IDE
.idea/
.vscode/
.DS_Store

# Coverage
*.cover
coverage.txt

# mkdocs build output (deployed via gh-pages workflow, not checked in)
/site/
